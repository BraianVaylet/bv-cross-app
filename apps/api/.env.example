# === BV Cross API — variables de entorno ===
# Copiar a .env para desarrollo local. Producción: cargar en el hosting.

# Entorno: development | test | production
NODE_ENV=development

# Puerto HTTP
PORT=8787

# MongoDB (Atlas SRV en prod; local en dev)
MONGODB_URI=mongodb://localhost:27017/bvcross

# Secreto de firma de access tokens (min 32 chars). Generar: openssl rand -base64 48
JWT_SECRET=cambiame-en-desarrollo-tambien-min-32-chars

# Vida del access token (minutos) y del refresh token (días)
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# Dominio de la cookie de refresh en prod (ej: .bvcross.app). Vacío en dev (host-only).
COOKIE_DOMAIN=

# Orígenes de los 3 frontends en prod (CSV). Vacío en dev (se permite localhost).
APP_ORIGINS=

# Emails
EMAIL_FROM=no-reply@bvcross.local
# Sin RESEND_API_KEY los emails salen por consola (dev)
RESEND_API_KEY=

# Respetar x-forwarded-* del proxy del hosting (true en prod)
TRUST_PROXY=false
